{
  "name": "pantry",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "A capability-scoped recipe store on Cloudflare Workers + D1. It stores and hands back scripts; it never runs them.",
  "exports": {
    ".": "./src/client.ts",
    "./recipe": "./src/recipe.ts",
    "./opencode": "./extensions/opencode/index.ts"
  },
  "scripts": {
    "dev": "wrangler dev",
    "build:site": "bun scripts/build-site.ts",
    "evals": "bun evals/run.ts",
    "test": "bun test ./test/*.test.ts",
    "typecheck": "tsc --noEmit",
    "check": "bun run typecheck && bunx --bun @biomejs/biome check . && bun run test",
    "deploy": "wrangler deploy",
    "db:migrate:remote": "wrangler d1 migrations apply pantry-db --remote"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@cloudflare/workers-types": "^4.20240909.0",
    "@types/bun": "latest",
    "alchemy": "^0.93.12",
    "typescript": "^5.9.2",
    "wrangler": "^4.102.0",
    "@opencode-ai/plugin": "1.4.6"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "gpt-tokenizer": "^3.4.0",
    "hono": "^4.12.25"
  },
  "author": "Jordan Coeyman (https://coey.dev)",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "pantry": "./bin/pantry",
    "pantry-mcp": "./bin/pantry-mcp"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.4.0"
  },
  "peerDependenciesMeta": {
    "@opencode-ai/plugin": {
      "optional": true
    }
  }
}
